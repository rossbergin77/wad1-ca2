      <div class="ui card">
        <div class="image">
          <img src="{{picture.url}}">
        </div>
        <div class="content">
          <a class="header">{{uppercase title}}</a> 
          <p>
            <i class="game icon"></i>
            {{#if games}}
              Total games: {{games.length}}
            {{else}}
              Empty collection!
            {{/if}}

            {{#if date}}
              <br>
              <i class="calendar alternate outline icon"></i>
              Created on <i>{{formatDate date}}</i>
            {{/if}}
          </p>
          {{#if rating}}
            <p>
                <span 
                   class="ui yellow disabled rating" 
                   data-icon="star" 
                   data-rating="{{rating}}" 
                   data-max-rating="5">
                </span>

                <span style="color: grey; font-size: 90%; font-style: italic">
                {{highlightPopular rating}}
              </span>
            </p>
          {{/if}}
        </div>
        
        <div class="extra content">
          <a href="/collection/{{id}}" >
            <i class="ui open folder outline black icon"></i>
          </a>
          <a href="/dashboard/deletecollection/{{id}}" >
            <i class="ui black trash icon"></i>
          </a>
        </div>
          
      </div>
