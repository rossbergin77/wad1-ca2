{{#if games}}

  <table class="ui unstackable striped table">
    <thead>
      <tr>
        <th class="four wide">Game</th>
        <th class="four wide">Percentage</th>
        <th class="two wide"> </th>
        <th class="two wide"> </th>
      </tr>
    </thead>
    <tbody>
      
      {{#each games}}
      
        {{> listOneGame collectionId=../id}}
        {{> editgame collectionId=../id}}
<script>
      document.querySelector("#showEdit{{@index}}").addEventListener ('click', () => {
            document.querySelector("#game{{@index}}").style.display = "none";
            document.querySelector("#edit{{@index}}").style.display = "table-row";
       })
      document.querySelector("#hideEdit{{@index}}").addEventListener ('click', () => {
            document.querySelector("#game{{@index}}").style.display = "table-row";
            document.querySelector("#edit{{@index}}").style.display = "none";
       })
</script>


      {{/each}}
    
    </tbody>
  </table>

{{else}}
  <h3 class="ui message">
    Empty collection!
  </h3>

{{/if}}




