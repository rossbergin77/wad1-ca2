<section class="ui left aligned middle aligned segment">

  {{> dashboardHeader }}

  {{#unless search}}
    {{#unless collections}}
    <h3 class="ui message">
      Start adding your collections!
    </h3>
    {{/unless}}
  {{/unless}}

  <div class="ui centered cards">
    
    {{#each collections}}
      {{> collectionCard}}
    {{/each}}
    
  </div>

</section>

